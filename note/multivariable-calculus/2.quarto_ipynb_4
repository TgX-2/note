        "#| echo: true\n",
        "#| code-fold: true\n",
        "#| warning: false\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "def f(x, y):\n",
        "    return - x**2 + y**2\n",
        "\n",
        "def fx(x, y):\n",
        "    return 2 * x\n",
        "\n",
        "def fy(x, y):\n",
        "    return 2 * y\n",
        "\n",
        "x0, y0 = 0, 0\n",
        "z0 = f(x0, y0)\n",
        "\n",
        "x = np.linspace(-5, 5, 50)\n",
        "y = np.linspace(-5, 5, 50)\n",
        "X, Y = np.meshgrid(x, y)\n",
        "Z = f(X, Y)\n",
        "\n",

        "___\n",
        "# Differentials, Chain rule\n",
        "\n",
        ":::{.callout-important}\n",
        "## tl;dr\n",
        "$$\n",
        "\\mathbf df = \\sum f_{x_i}\\mathbf d{x_i}\n",
